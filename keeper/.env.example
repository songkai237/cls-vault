# RPC endpoint (required)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Strategy owner private key (required, no 0x prefix or with 0x both ok)
PRIVATE_KEY=

# Deployed UniswapV3Strategy address (required)
STRATEGY_ADDRESS=

# Poll interval in seconds (default: 12)
POLL_INTERVAL=12

# Set to 1 or true to monitor without sending transactions
DRY_RUN=true

# Optional chain id (default: from RPC)
# CHAIN_ID=1

# Optional idle thresholds; default uses strategy min swap amounts
# MIN_IDLE_AMOUNT0=100000000
# MIN_IDLE_AMOUNT1=10000000000000000
